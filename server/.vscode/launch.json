{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "debug with make",
      "type": "cppdbg",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/build/main",
      "MIMode": "gdb",
      "args": [
        "DEBUG"
      ],
      "preLaunchTask": "debug make",
      "miDebuggerPath": "gdb"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "/home/bruno/Projects/file_server/server/src",
      "program": "/home/bruno/Projects/file_server/server/src/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}